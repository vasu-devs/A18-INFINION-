# ─── LLM Provider ─────────────────────────────────────────
# Options: "openai", "gemini", "ollama"
LLM_PROVIDER=openai

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Google Gemini ────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama (Local) ──────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── MCP Server ──────────────────────────────────────────
MCP_SERVER_URL=
MCP_TRANSPORT=stdio
MCP_SERVER_COMMAND=
MCP_SERVER_ARGS=

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
